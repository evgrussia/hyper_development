# Universal Backend MVP — корень монорепо (Phase 0)
# Скопировать в .env и подставить значения.
# Backend: backend/.env.example  Frontend: frontend/.env.example

# === Docker Compose (общие) ===
DEBUG=true
DJANGO_SECRET_KEY=change-me-in-production
POSTGRES_DB=universal_backend
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# CORS (origins для frontend)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://127.0.0.1:3000,http://127.0.0.1:5173

# Telegram (Phase 1) — токен из BotFather
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBAPP_AUTH_MAX_AGE_SECONDS=86400

# === Frontend (Vite) — для локальной разработки ===
# VITE_API_BASE_URL=http://localhost:8000/api
# VITE_TELEGRAM_BOT_NAME=
