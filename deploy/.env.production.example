# Production env для VPS (hyper-development)
# Путь на VPS: /home/deploy/hyper_development/.env — подставить реальные значения.
# Не коммитить .env в репо.

DEBUG=false
DJANGO_SETTINGS_MODULE=config.settings.production
DJANGO_SECRET_KEY=<сгенерировать-длинный-секрет>
ALLOWED_HOSTS=base-front.hyper-development.ru,localhost,127.0.0.1,backend
POSTGRES_DB=universal_backend
POSTGRES_USER=postgres
POSTGRES_PASSWORD=<надёжный-пароль>
CORS_ALLOWED_ORIGINS=https://base-api.hyper-development.ru
VITE_API_BASE_URL=https://base-front.hyper-development.ru/api
TELEGRAM_BOT_TOKEN=<токен-из-BotFather>
TELEGRAM_WEBAPP_AUTH_MAX_AGE_SECONDS=86400
